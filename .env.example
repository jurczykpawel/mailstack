# Deployment config for generating wrangler.toml (NOT secrets — secrets go via `wrangler secret put`).
# Copy to .env and fill in; `npm run setup` substitutes these into wrangler.toml.
#   cp .env.example .env

# Rate-limiter KV namespace ids. Create them once:
#   wrangler kv namespace create RATE_LIMIT
#   wrangler kv namespace create RATE_LIMIT --preview
MAILSTACK_KV_ID=
MAILSTACK_KV_PREVIEW_ID=

# Optional custom domain for the Worker (leave empty to use the default *.workers.dev URL).
# Its zone must live in the same Cloudflare account as the Worker.
MAILSTACK_ROUTE=
